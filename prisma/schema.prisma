// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PublishStatus {
  DRAFT
  PUBLISHED
}

enum ProgressStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

model Course {
  id          String        @id @default(uuid())
  title       String
  description String
  thumbnail   String?
  level       String
  category    String
  status      String        @default("PUBLISHED") // "DRAFT", "PUBLISHED", "ARCHIVED"
  sortOrder   Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  stages      Stage[]
  exercises   Exercise[]
}

model Stage {
  id             String          @id @default(uuid())
  code           String
  courseId       String?
  course         Course?         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title          String
  description    String
  goal           String
  order          Int
  bigExercise    String          @default("")
  expectedOutput String          @default("")
  finalChecklist String          @default("")
  status         PublishStatus   @default(PUBLISHED)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  lessons        Lesson[]
  stagePractices StagePractice[]
}

model Lesson {
  id                     String                @id @default(uuid())
  code                   String
  stageId                String
  stage                  Stage                 @relation(fields: [stageId], references: [id], onDelete: Cascade)
  title                  String
  order                  Int
  objective              String
  theory                 String
  example                String
  smallExercise          String                @default("")
  realProjectApplication String
  expectedOutput         String
  htmlContent            String                @default("")
  status                 PublishStatus         @default(PUBLISHED)
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt
  checklistItems         LessonChecklistItem[]
  lessonPractices        LessonPractice[]
  exercises              Exercise[]

  @@unique([stageId, title])
}

model LessonChecklistItem {
  id        String   @id @default(uuid())
  lessonId  String
  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  content   String
  order     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LessonPractice {
  id          String   @id @default(uuid())
  lessonId    String
  lesson      Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  projectName String   @default("")
  content     String   @default("")
  reflection  String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model StagePractice {
  id          String   @id @default(uuid())
  stageId     String
  stage       Stage    @relation(fields: [stageId], references: [id], onDelete: Cascade)
  projectName String   @default("")
  content     String   @default("")
  reflection  String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Exercise {
  id          String   @id @default(uuid())
  courseId    String?
  course      Course?  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessonId    String?
  lesson      Lesson?  @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  title       String
  description String
  instruction String   @default("")
  type        String   // "lesson_exercise" hoặc "course_project"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Progress {
  id          String         @id @default(uuid())
  entityType  String         // "STAGE" hoặc "LESSON" hoặc "COURSE"
  entityId    String
  status      ProgressStatus @default(NOT_STARTED)
  userId      String?
  courseId    String?
  completedAt DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@unique([entityType, entityId])
}

model ChecklistProgress {
  id              String   @id @default(uuid())
  checklistItemId String   @unique // linked to LessonChecklistItem id
  isChecked       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
